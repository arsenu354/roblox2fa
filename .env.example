# Google OAuth (из Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URL твоего Netlify сайта (например https://roblox2fa.netlify.app)
APP_URL=

# Firebase Admin SDK (из Firebase Console → Project Settings → Service accounts → Generate new private key)
FIREBASE_ADMIN_PROJECT_ID=project-9e35b839-f404-4a58-ae2
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
